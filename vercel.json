{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html",             "destination": "/",             "permanent": true },
    { "source": "/contact.html",           "destination": "/contact",      "permanent": true },
    { "source": "/blog.html",              "destination": "/blog",         "permanent": true },
    { "source": "/team.html",              "destination": "/team",         "permanent": true },
    { "source": "/testimonials.html",      "destination": "/testimonials", "permanent": true },
    { "source": "/communities.html",       "destination": "/communities",  "permanent": true },
    { "source": "/communities/:slug.html", "destination": "/communities/:slug", "permanent": true },
    { "source": "/team-page/:slug.html",   "destination": "/team/:slug",   "permanent": true },
    { "source": "/team-page/:slug",        "destination": "/team/:slug",   "permanent": true },
    { "source": "/blog/:slug.html",        "destination": "/blog/:slug",   "permanent": true }
  ]
}